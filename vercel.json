{
  "version": 2,
  "framework": null,
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    },
    "api/python.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/python/:path*", "destination": "/api/python" },
    { "source": "/api/:path*",        "destination": "/api/index" },
    { "source": "/:path*",            "destination": "/index.html" }
  ]
}
