# ─── OpenRouter (AI) ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# ─── FRED (Federal Reserve Economic Data) ─────────────────────────────────────
# 免費申請：https://fred.stlouisfed.org/docs/api/api_key.html
# 無此 Key 仍可運作（部分端點受限）
FRED_API_KEY=

# ─── ECPay 綠界金流 ─────────────────────────────────────────────────────────────
# 申請正式帳號: https://www.ecpay.com.tw/
# 測試環境帳號 (sandbox 預設，直接可用):
ECPAY_MERCHANT_ID=2000132
ECPAY_HASH_KEY=5294y06JbISpM5x9
ECPAY_HASH_IV=v77hoKGq4kWxNNIS
# 改為 production 才使用正式端點
ECPAY_ENV=sandbox

# ─── Application ──────────────────────────────────────────────────────────────
# 務必設定為你的實際網域 (ECPay notify/return 需要公開 URL)
# 本機測試請使用 ngrok: ngrok http 3000
APP_BASE_URL=https://your-domain.com

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/stockdb

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here

# ─── Vercel (自動注入，本機不需設定) ─────────────────────────────────────────────
# VERCEL=1
# VERCEL_ENV=production

# ─── Science/Quantum Signals (Task 1 + Task 2) ──────────────────────────────
ENABLE_QUANTUM_SIGNAL=false
SCIENCE_SERVICE_URL=http://127.0.0.1:8788
SCIENCE_SERVICE_TIMEOUT_MS=7000
SCIENCE_SERVICE_RETRY=1
SCIENCE_SERVICE_CACHE_TTL_MS=60000
